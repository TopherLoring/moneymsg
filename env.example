# MoneyMsg — Environment Variables
# v1.0.0 — 2026.04.17

# ─── Database ───────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/moneymsg
DB_SSL_MODE=disable
# DB_SSL_CA=/path/to/ca-cert.pem

# ─── Auth & Session ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_AT_LEAST_32_CHARS_RANDOM_STRING
JWT_ISSUER=moneymsg
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ─── Webhook Security ──────────────────────────────────────────────
TABAPAY_WEBHOOK_SECRET=changeme
DWOLLA_WEBHOOK_SECRET=changeme
WEBHOOK_SHARED_SECRET=changeme
WEBHOOK_MAX_SKEW_SECONDS=300

# ─── Alviere ────────────────────────────────────────────────────────
ALVIERE_API_KEY=changeme
ALVIERE_API_URL=https://api.alviere.com

# ─── Plaid ──────────────────────────────────────────────────────────
PLAID_CLIENT_ID=changeme
PLAID_SECRET=changeme
PLAID_ENV_URL=https://sandbox.plaid.com

# ─── TabaPay ────────────────────────────────────────────────────────
TABAPAY_API_KEY=changeme
TABAPAY_API_URL=https://api.tabapay.com

# ─── Dwolla ─────────────────────────────────────────────────────────
DWOLLA_APP_KEY=changeme
DWOLLA_APP_SECRET=changeme
DWOLLA_ENV_URL=https://api.dwolla.com
DWOLLA_DEST_FUNDING_SOURCE=https://api.dwolla.com/funding-sources/your-destination-id
DWOLLA_SOURCE_FUNDING_SOURCE=https://api.dwolla.com/funding-sources/your-source-id

# ─── App ────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
