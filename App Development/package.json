{
  "name": "moneymsg-backend",
  "version": "0.1.0",
  "description": "MoneyMsg Fastify backend (Cloud Run)",
  "main": "dist/server.js",
  "type": "commonjs",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "bun run scripts/lint.ts",
    "test": "bun test",
    "dev": "bun --hot src/server.ts",
    "start": "bun dist/server.js",
    "dev:sweeper": "bun --hot src/workers/intentSweeper.ts",
    "start:sweeper": "bun dist/workers/intentSweeper.js",
    "dev:request-sweeper": "bun --hot src/workers/requestSweeper.ts",
    "start:request-sweeper": "bun dist/workers/requestSweeper.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate:pg",
    "smoke": "bun run scripts/smoke.ts",
    "ci": "bun run lint && bun run typecheck && bun test && bun run build && bun run db:check && bun run smoke",
    "db:check": "bun x drizzle-kit check --config drizzle.config.ts"
  },
  "keywords": [
    "fastify",
    "drizzle",
    "moneymsg"
  ],
  "author": "TopherLoring Industries",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
